# Runtime
FPA_ROOT_DIR=
FPA_STATE_DIR=
FPA_DB_PATH=
FPA_BACKUP_DIR=
FPA_EXPORT_DIR=
FPA_LOG_DIR=
FPA_AUDIT_DIR=

# Logging
FPA_LOG_LEVEL=INFO
FPA_LOG_TO_STDERR=true
FPA_LOG_FILE_NAME=app.log
FPA_LOG_JSON=false

# LLM provider
FPA_LLM_PROVIDER=host
FPA_LLM_MODEL=
FPA_LLM_BASE_URL=
FPA_LLM_API_KEY=
FPA_LLM_API_PATH=/responses
FPA_LLM_TIMEOUT_SECONDS=60
FPA_LLM_MAX_OUTPUT_TOKENS=1200
FPA_LLM_MAX_RETRIES=3
FPA_LLM_RETRY_INITIAL_BACKOFF_SECONDS=1
FPA_LLM_RETRY_MAX_BACKOFF_SECONDS=8
FPA_LLM_TEMPERATURE=0
FPA_LLM_ORGANIZATION=
FPA_ANTHROPIC_VERSION=2023-06-01

# Review behavior
FPA_SEMANTIC_REVIEW_AUTO_APPROVE=false
